    P_cond_w_liq = (lam_w * A_cross / dx) * (Tw[-1] - Tw_vap)

    # Mise à jour de la température de paroi vapeur
    dTw_vap_dt = (P_ext_v - P_conv_v + P_cond_w_liq) / capa_wv_total
