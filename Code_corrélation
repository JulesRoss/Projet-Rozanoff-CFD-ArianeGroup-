            temp_new = temp_bulk[i] + tau_i / (rho_l * g * beta_l * delta[i]) + \
                       3.25 * 0.5 * (m_point_CL[i+1] + m_point_CL[i]) * (2 * A_grad) / ((2 * np.pi * R * rho_l * delta[i])**2) / (g * beta_l)

